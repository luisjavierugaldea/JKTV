# =============================================
# STREMIO CLONE — Variables de Entorno
# =============================================
# Copia este archivo a .env y rellena los valores

# Servidor
PORT=3001
NODE_ENV=development

# TMDB API — Obtenla en https://www.themoviedb.org/settings/api
TMDB_API_KEY=tu_api_key_aqui
TMDB_BASE_URL=https://api.themoviedb.org/3

# Supabase — Obtenlo en https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui

# CORS — Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Scrapers — Configuración de Playwright
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
